# ==========================================
# Build & Spark Project Output
# ==========================================
target/
spark-warehouse/
metastore_db/
checkpoint/
checkpoints/
.spark-staging/
logs/
derby.log
eventLog/
spark-events/
part-*
_SUCCESS
_committed_*
