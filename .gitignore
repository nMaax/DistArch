# ==========================================
# local Environment (direnv & uv)
# ==========================================
# We ignore the direnv internal cache
.direnv/

# IMPORTANT: Usually, you COMMIT .envrc so others can use it.
# But if you have personal paths (like your specific Arch username),
# you might want to use .envrc.local for those and ignore it here.
.envrc.local

# uv lock file is usually COMMITTED (like package-lock.json),
# but if you prefer to only share the pyproject.toml, uncomment below:
# uv.lock

